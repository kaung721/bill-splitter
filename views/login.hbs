<div class="d-flex justify-content-center">
  <div class="card p-4 auth-wrapper auth-card w-100">
    <h2 class="mb-3 text-center">Login</h2>
    <p class="text-muted small text-center mb-4">
      Continue where you left off with your shared bills.
    </p>
    <form method="POST" action="/login" class="mb-3">
      <div class="mb-3">
        <label for="email" class="form-label">Email address</label>
        <input type="email" class="form-control" id="email" name="email" required>
      </div>
      <div class="mb-3">
        <label for="password" class="form-label">Password</label>
        <input type="password" class="form-control" id="password" name="password" required>
      </div>
      <button type="submit" class="btn btn-dark w-100">Login</button>
    </form>
    <div class="d-grid gap-2">
      <a class="btn btn-outline-secondary btn-md" href="/auth/google">
        <i class="bi bi-google me-2"></i>Sign in with Google
      </a>
      <a class="btn btn-outline-secondary btn-md" href="/auth/github">
        <i class="bi bi-github me-2"></i>Sign in with Github
      </a>
    </div>
    <p class="mt-3 text-center small">
      Don't have an account?
      <a href="/register">Register here</a>
    </p>
  </div>
</div>