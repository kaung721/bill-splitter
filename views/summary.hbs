{{!-- Summary of bill splits. Shows who owes whom and how much --}}
<div class="card p-4">
  <h3>Split Summary — {{bill.storeName}}</h3>
  <p>Total: ${{formatCents bill.totalAmountCents}}</p>

  <ul class="list-group">
    {{#each payments}}
      <li class="list-group-item d-flex justify-content-between align-items-center">
        {{this.fromName}} owes {{this.toName}} <strong>${{this.amount}}</strong>
      </li>
    {{/each}}
  </ul>

  <a class="btn btn-link mt-3" href="/dashboard">Back</a>
</div>
